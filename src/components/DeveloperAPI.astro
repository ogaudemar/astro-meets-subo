---
const { translations } = Astro.props;
const { title, subtitle, features, ctaDocs, ctaKey } = translations;
---

<section class="developer-api">
  <div class="container">
    <header class="developer-api__header">
      <div class="developer-api__badge">REST API</div>
      <h2 class="developer-api__title">{title}</h2>
      <p class="developer-api__subtitle">{subtitle}</p>
    </header>
    <div class="developer-api__grid">
      {features.map((feature, i) => (
        <div class="dev-card">
          <span class="dev-card__icon">
            {i === 0 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
              </svg>
            )}
            {i === 1 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                <path d="M3 5V19A9 3 0 0 0 21 19V5"></path>
                <path d="M3 12A9 3 0 0 0 21 12"></path>
              </svg>
            )}
            {i === 2 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
              </svg>
            )}
          </span>
          <h3 class="dev-card__title accent">{feature.title}</h3>
          <ul>
            {feature.content.map(line => (
              <li>{line}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="developer-api__ctas">
      <a href="https://api.subo.ai/docs" class="button button--accent-bg" target="_blank" rel="noopener noreferrer">{ctaDocs}</a>
      <a href="https://app.subo.gg/app/account" class="button button--primary-border" target="_blank" rel="noopener noreferrer">{ctaKey}</a>
    </div>
  </div>
</section>

<style>
  .accent {
    color: var(--accent);
  }

  .developer-api {
    padding: 4rem 0;
    background: linear-gradient(var(--dark), var(--primary-dark));
  }

  .developer-api__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .developer-api__badge {
    display: inline-block;
    font-family: monospace;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    background: rgba(116, 83, 153, 0.25);
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 4px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1rem;
  }

  .developer-api__title {
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .developer-api__subtitle {
    font-size: 1.2rem;
    color: #ccc;
    margin: 0 auto;
    max-width: 640px;
  }

  .developer-api__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .dev-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 1.2rem;
    padding: 2rem 1.5rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.10);
    transition: transform 0.15s, box-shadow 0.15s, background 0.2s;
  }

  .dev-card:hover {
    box-shadow: 0 6px 16px var(--accent);
    background: rgba(116, 83, 153, 0.4);
  }

  .dev-card__icon {
    font-size: 2rem;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary);
    border-radius: 50%;
  }

  .dev-card__title {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 1rem 0;
  }

  .dev-card ul {
    padding-left: 0.2rem;
    margin: 0;
    list-style: none;
  }

  .dev-card li {
    font-size: 1.05rem;
    margin-bottom: 0.7rem;
    line-height: 1.6;
    padding-left: 1.2rem;
  }

  .dev-card li::before {
    content: "→ ";
    color: var(--accent);
    margin-left: -1.2rem;
  }

  .developer-api__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 700px) {
    .developer-api {
      padding: 2rem 0;
    }

    .developer-api__title {
      font-size: 1.4rem;
    }

    .developer-api__subtitle {
      font-size: 1rem;
    }

    .dev-card {
      padding: 1.5rem;
    }

    .dev-card__icon {
      width: 50px;
      height: 50px;
      font-size: 1.5rem;
    }
  }
</style>
