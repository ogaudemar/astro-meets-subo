---
const { translations } = Astro.props;

const ctaTitle = translations.ctaTitle;
const ctaSubtitle = translations.ctaSubtitle;
const ctaButton = translations.ctaButton;
---

<section class="cta">
  <div class="container text-center">
    <h2 class="cta__title">{ctaTitle}</h2>
    <p class="subtitle">{ctaSubtitle}</p>
    <div class="cta__buttons">
      <a href="/pricing" class="button button--accent-bg">{ctaButton}</a>
      <a href="/invite" class="button button--primary-border" target="_blank" rel="noopener noreferrer">{translations.header.cta}</a>
    </div>
  </div>
</section>

<style>
.cta {
  padding: 3rem;
  background:
    radial-gradient(75% 120% at 50% 100%, var(--bg-glow-pink), transparent 70%),
    var(--bg-base);
}

.cta__title {
  padding: 1.5rem 0;
}

.cta__buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 1.5rem;
}
</style>