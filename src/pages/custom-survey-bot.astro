---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import translations from '../content/translations/en.json';

const t = translations.customSurveyBot;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={t.pageTitle} description={t.pageDescription} alternates={[
      {lang: 'x-default', href: 'https://subo.gg/custom-survey-bot'},
      {lang: 'en', href: 'https://subo.gg/custom-survey-bot'},
      {lang: 'fr', href: 'https://subo.gg/fr/custom-survey-bot'},
    ]} />
	</head>
	<body>
		<Header translations={translations.header} />
		<main>
			<!-- Hero Section -->
			<section class="hero dark">
				<div class="container">
					<div class="hero__content">
						<div class="hero__text">
							<h1 class="hero__title">{t.hero.title}</h1>
							<p class="subtitle text-white">{t.hero.subtitle}</p>
							<div class="hero__buttons">
								<a href={t.hero.ctaPrimary.href} class="button button--white-bg">
									{t.hero.ctaPrimary.text}
								</a>
								<a href={t.hero.ctaSecondary.href} class="button button--white-outline">
									{t.hero.ctaSecondary.text}
								</a>
							</div>
						</div>
						<div class="hero__image">
							<img
								src={t.hero.image.src}
								alt={t.hero.image.alt}
								class="hero__bot-image"
							/>
						</div>
					</div>
				</div>
			</section>

			<!-- Features Comparison -->
			<section class="comparison dark2secondarydark">
				<div class="container">
					<h2 class="section-title" set:html={t.comparison.title} />
					<p class="section-subtitle">{t.comparison.subtitle}</p>
					<div class="comparison__grid">
						{t.comparison.cards.map((card) => (
							<div class="comparison__card">
								<div class="comparison__icon">{card.icon}</div>
								<h3 class="comparison__title">{card.title}</h3>
								<ul class="comparison__list">
									{card.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- HOW IT WORKS -->
			<section class="how-it-works secondarydark2primarydark">
				<div class="container">
					<h2 class="section-title">{t.howItWorks.title}</h2>
					<div class="steps">
						{t.howItWorks.steps.map((step) => (
							<div class="step">
								<div class="step__number">{step.number}</div>
								<div class="step__content">
									<h3 class="step__title">{step.title}</h3>
									<p class="step__description">{step.description}</p>
									<a
										href={step.link.href}
										class="step__link"
										{...(step.link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
									>
										{step.link.text}
									</a>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- FAQ Section -->
			<section class="faq primarydark2secondarydark">
				<div class="container">
					<h2 class="section-title">{t.faq.title}</h2>
					<div class="faq__grid">
						{t.faq.items.map((item) => (
							<div class="faq__item">
								<h3 class="faq__question">{item.question}</h3>
								<p class="faq__answer">{item.answer}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- CTA Section -->
			<section class="cta secondarydark2dark">
				<div class="container">
					<div class="cta__content">
						<h2 class="cta__title">{t.ctaSection.title}</h2>
						<p class="cta__description">{t.ctaSection.description}</p>
						<div class="cta__buttons">
							<a href={t.ctaSection.ctaPrimary.href} class="button button--primary-bg">
								{t.ctaSection.ctaPrimary.text}
							</a>
							<a href={t.ctaSection.ctaSecondary.href} class="button button--white-outline">
								{t.ctaSection.ctaSecondary.text}
							</a>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer translations={translations.footer} />
	</body>
</html>


<style>


.accent {
    color: var(--accent);
}


  /* Legacy section-gradient utilities, flattened to the single page base.
     The hero and CTA opt back into accent glows below. */
  .dark2secondarydark,
  .secondarydark,
  .secondarydark2secondary,
  .secondarydark2dark,
  .secondarydark2primarydark,
  .primarydark2dark,
  .primary2secondarydark,
  .primarydark2secondarydark {
    background: transparent;
  }





  .hero {
        padding: 100px 0;
    overflow: hidden;
    background:
      radial-gradient(70% 55% at 50% 0%, var(--bg-glow-pink), transparent 70%),
      var(--bg-base);
  }


  .hero__content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: center;
  }



  .hero__title {
    font-family: "IBM Plex Mono", "Source Code Pro", monospace;
    letter-spacing: -0.02em;
    font-size: 4rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .hero__subtitle {
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .hero__description {
    font-size: 1.25rem;
    color: #ccc;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero__buttons {
    display: flex;
    gap: 1rem;
  }

  .hero__image {
    text-align: center;
  }

  .hero__bot-image {
    width: 400px;
    /*height: 200px;*/
    border-radius: 5%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .button {
    display: inline-block;
    padding: 15px 30px;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s ease;
  }

  .button--accent {
    background: var(--accent);
    color: white;
  }

  .button--accent:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }

  .button--white-outline {
    background: transparent;
    color: white;
    border: 2px solid white;
  }

  .button--white-outline:hover {
    background: white;
    color: black;
  }

  .comparison {
    padding: 80px 0;

  }

  .section-title {
    font-size: 3.5rem;
    font-weight: 700;
    color: white;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: #ccc;
    text-align: center;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .comparison__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 3rem;
  }

  .comparison__card {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-white);
    padding: 3rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

    .comparison__card:hover {
      box-shadow: 0 6px 16px var(--primary);
      background: rgba(255, 255, 255, 0.1);
      opacity: 1;
  }

  .comparison__icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .comparison__title {
    font-size: 1.5rem;
    font-weight: 700;
    /*color: white;*/
    margin-bottom: 1.5rem;
  }

  .comparison__list {
    text-align: left;
    /*color: #ccc;*/
    line-height: 1.8;
  }

  .comparison__list li {
    margin-bottom: 1rem;
    padding-left: 1rem;
    position: relative;
  }

  .comparison__list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: bold;
  }

  .how-it-works {
    padding: 80px 0;

  }

  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .step {
    background: rgba(255, 255, 255, 0.05);
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .step__number {
    background: var(--primary);
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0 auto 1.5rem auto;
  }

  .step__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }

  .step__description {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .step__link {
    display: inline-block;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 2px solid var(--accent);
    transition: all 0.3s ease;
  }

  .step__link:hover {
    color: white;
    border-color: white;
  }

  .faq {
    padding: 80px 0;

  }

  .faq__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: 2rem;
  }

  .faq__item {
    background: rgba(255, 255, 255, 0.05);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq__question {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1rem;
  }

  .faq__answer {
    color: #ccc;
    line-height: 1.6;
  }

  .cta {
    padding: 80px 0;
    text-align: center;
    background:
      radial-gradient(75% 120% at 50% 100%, var(--bg-glow-pink), transparent 70%),
      var(--bg-base);
  }

  .cta__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .cta__title {
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
  }

  .cta__description {
    font-size: 1.25rem;
    color: #ccc;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .hero__content {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .hero__title {
      font-size: 2.25rem;
    }

    .hero__subtitle {
      font-size: 1.25rem;
    }

    .hero__buttons,
    .cta__buttons {
      flex-direction: column;
      align-items: center;
    }

    .comparison__grid {
      grid-template-columns: 1fr;
    }

    .steps {
      grid-template-columns: 1fr;
    }

    .faq__grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 2rem;
    }

    .cta__title {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .hero__title {
      font-size: 2rem;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .cta__title {
      font-size: 1.75rem;
    }
  }
</style>
