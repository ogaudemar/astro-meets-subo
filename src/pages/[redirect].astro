---
import { trackedRedirects } from '../config/redirects.js';
import BaseHead from '../components/BaseHead.astro';
import en from '../content/translations/en.json';
import fr from '../content/translations/fr.json';
import de from '../content/translations/de.json';
import es from '../content/translations/es.json';
import it from '../content/translations/it.json';
import ptBr from '../content/translations/pt-br.json';

export function getStaticPaths() {
  return Object.keys(trackedRedirects).map(key => ({
    params: { redirect: key },
  }));
}

const { redirect } = Astro.params;
const redirectData = trackedRedirects[redirect];

if (!redirectData) {
  return new Response(null, { status: 404 });
}

const i18n = {
  en: en.redirectPage,
  fr: fr.redirectPage,
  de: de.redirectPage,
  es: es.redirectPage,
  it: it.redirectPage,
  'pt-br': ptBr.redirectPage,
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={`Redirecting to ${redirectData.description}`} />
  <meta http-equiv="refresh" content={`1;url=${redirectData.url}`} />

  <style>
    body {
      font-family: 'IBM Plex Mono', -apple-system, BlinkMacSystemFont, Roboto, mono, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      background: var(--bg-base);
      color: white;
      text-align: center;
    }
    .loader-gif {
      width: 64px;
      height: 64px;
      margin-bottom: 20px;
      image-rendering: pixelated;
    }
    a {
      color: white;
      text-decoration: underline;
      margin-top: 20px;
      display: inline-block;
    }
  </style>
</head>
<body>
  <img class="loader-gif" src="/subo-equalizer.gif" alt="Loading..." />
  <h3 id="redir-heading">Redirecting to {redirectData.description}...</h3>
  <p id="redir-auto">You'll be redirected automatically in a moment.</p>
  <a id="redir-manual" href={redirectData.url}>Click here if you're not redirected automatically</a>

  <script define:vars={{ i18n, description: redirectData.description, redirectUrl: redirectData.url, redirectName: redirectData.name }}>
    // Prefer the locale the user came from (referrer URL path takes priority over browser language)
    var refMatch = document.referrer.match(/\/(?:fr|de|es|it|pt-br)\//);
    var lang;
    if (refMatch) {
      lang = refMatch[0].replace(/\//g, '');
    } else {
      var raw = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
      lang = raw.startsWith('pt') ? 'pt-br' : raw.slice(0, 2);
    }
    var t = i18n[lang] || i18n['en'];
    document.getElementById('redir-heading').textContent = t.redirecting + ' ' + description + '...';
    document.getElementById('redir-auto').textContent = t.auto;
    document.getElementById('redir-manual').textContent = t.manual;

    // Track the redirect
    if (typeof gtag !== 'undefined') {
      gtag('event', 'redirect_click', {
        redirect_destination: redirectName,
        redirect_url: redirectUrl,
        redirect_description: description,
      });
    }

    // Redirect after tracking
    setTimeout(function() {
      window.location.href = redirectUrl;
    }, 1000);
  </script>
</body>
</html>
