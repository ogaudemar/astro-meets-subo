---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import translations from '../content/translations/en.json';

const t = translations.featuresPage;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={t.pageTitle} description={t.pageDescription} alternates={[
      {lang: 'x-default', href: 'https://subo.gg/features'},
      {lang: 'en', href: 'https://subo.gg/features'},
      {lang: 'fr', href: 'https://subo.gg/fr/features'},
    ]} />
  </head>
  <body>
    <Header translations={translations.header} />
    <main id="main-content">

      <!-- Hero -->
      <section class="feat-hero">
        <div class="container text-center">
          <h1 class="mono">{t.hero.title}</h1>
          <p class="feat-hero__subtitle">{t.hero.subtitle}</p>
          <a href="/invite" class="button button--accent-bg">{t.hero.cta}</a>
        </div>
      </section>

      <!-- Section nav pills -->
      <nav class="feat-nav" aria-label="Feature sections">
        <div class="feat-nav__inner">
          {t.nav.map((pill) => (
            <a href={`#${pill.anchor}`} class="feat-nav__pill mono">{pill.label}</a>
          ))}
        </div>
      </nav>

      {t.sections.map((section, i) => (
        <section class={`feat-section ${i % 2 === 0 ? 'feat-section--secondary' : 'feat-section--dark'}`} id={section.id}>
          <div class="container">
            <div class="feat-section__header">
              <span class={`feat-label ${i % 2 === 0 ? 'feat-label--accent' : 'feat-label--primary'} mono`}>{section.label}</span>
              <h2 class="feat-section__title">{section.title}</h2>
              <p class="feat-section__sub">{section.sub}</p>
            </div>
            <div class="feat-cards">
              {section.cards.map((card) => (
                <div class="feat-card">
                  <span class="feat-card__emoji">{card.emoji}</span>
                  <h3 class="feat-card__title">{card.title}</h3>
                  <p class="feat-card__desc" set:html={card.desc} />
                </div>
              ))}
            </div>
            <figure class={`feat-screenshot${section.screenshot.wide ? ' feat-screenshot--wide' : ''}`}>
              <img src={section.screenshot.src} alt={section.screenshot.alt} loading="lazy" />
              <figcaption>{section.screenshot.caption}</figcaption>
            </figure>
            <p class="feat-blog-link">
              <a href={section.blogLink.href}>{section.blogLink.text}</a>
            </p>
          </div>
        </section>
      ))}

      <CTA translations={translations} />
    </main>
    <Footer translations={translations.footer} />
  </body>
</html>

<style>
/* Hero */
.feat-hero {
  padding: 140px 0 80px;
  background:
    radial-gradient(70% 55% at 50% 0%, var(--bg-glow-pink), transparent 70%),
    var(--bg-base);
}
.feat-hero h1 {
  font-family: "IBM Plex Mono", "Source Code Pro", monospace;
  letter-spacing: -0.02em;
  font-size: clamp(1.8rem, 4.5vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1.25rem;
}
.feat-hero__subtitle {
  font-size: 1.15rem;
  color: var(--grey-light);
  max-width: 600px;
  margin: 0 auto 2rem;
}

/* Section nav */
.feat-nav {
  position: sticky;
  top: 57px; /* nav bar height */
  z-index: 100;
  background: rgba(19, 13, 28, 0.92);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}
.feat-nav__inner {
  display: flex;
  justify-content: center;
  gap: 0.25rem;
  padding: 0.6rem 1rem;
  flex-wrap: wrap;
}
.feat-nav__pill {
  display: inline-block;
  padding: 0.35rem 1rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--grey-light);
  text-decoration: none;
  border: 1px solid transparent;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
}
.feat-nav__pill:hover {
  color: var(--accent);
  border-color: var(--accent);
  background: rgba(255, 255, 255, 0.04);
}

/* Sections */
.feat-section {
  padding: 4rem 0;
}
.feat-section--secondary {
  background: transparent;
}
.feat-section--dark {
  background: transparent;
}

.feat-section__header {
  text-align: center;
  margin-bottom: 3rem;
}
.feat-section__title {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 800;
  margin: 0.75rem 0 0.75rem;
  line-height: 1.2;
}
.feat-section__sub {
  color: var(--grey-light);
  font-size: 1.05rem;
  max-width: 580px;
  margin: 0 auto;
  line-height: 1.65;
}

/* Section label pill */
.feat-label {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
}
.feat-label--accent {
  color: var(--accent);
  background: rgba(var(--accent-rgb, 99, 207, 138), 0.12);
  border: 1px solid rgba(var(--accent-rgb, 99, 207, 138), 0.25);
}
.feat-label--primary {
  color: var(--primary-light);
  background: rgba(var(--primary-rgb), 0.12);
  border: 1px solid rgba(var(--primary-rgb), 0.25);
}

/* Feature cards grid */
.feat-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}
.feat-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 1.75rem;
}
.feat-card__emoji {
  font-size: 1.75rem;
  display: block;
  margin-bottom: 0.75rem;
}
.feat-card__title {
  font-size: 1rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
}
.feat-card__desc {
  font-size: 0.9rem;
  color: var(--grey-light);
  line-height: 1.65;
  margin: 0;
}
.feat-card__desc code {
  font-family: monospace;
  background: rgba(255, 255, 255, 0.08);
  padding: 0.1em 0.35em;
  border-radius: 4px;
  font-size: 0.85em;
}

/* Screenshot placeholder */
.feat-screenshot {
  margin: 0 0 1.5rem;
}
.feat-screenshot__placeholder {
  aspect-ratio: 16 / 9;
  background: rgba(255, 255, 255, 0.04);
  border: 1px dashed rgba(255, 255, 255, 0.15);
  border-radius: 12px;
  margin-bottom: 0.75rem;
}
.feat-screenshot--wide .feat-screenshot__placeholder {
  aspect-ratio: 21 / 9;
}
.feat-screenshot img {
  display: block;
  width: 100%;
  border-radius: 12px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  margin-bottom: 0.75rem;
}
.feat-screenshot figcaption {
  font-size: 0.82rem;
  color: var(--grey-light);
  text-align: center;
  opacity: 0.7;
}

/* Blog link */
.feat-blog-link {
  text-align: center;
  margin: 0;
}
.feat-blog-link a {
  font-size: 0.9rem;
  color: var(--accent);
  text-decoration: none;
  transition: opacity 0.15s;
}
.feat-blog-link a:hover {
  opacity: 0.75;
  text-decoration: underline;
}

/* Responsive */
@media (max-width: 600px) {
  .feat-nav__pill {
    font-size: 0.7rem;
    padding: 0.3rem 0.75rem;
  }
  .feat-cards {
    grid-template-columns: 1fr;
  }
}
</style>
