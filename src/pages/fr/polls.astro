---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import translations from '../../content/translations/fr.json';

const t = translations.pollsPage;
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={t.pageTitle} description={t.pageDescription} alternates={[
			{lang: 'x-default', href: 'https://subo.gg/polls'},
			{lang: 'en', href: 'https://subo.gg/polls'},
			{lang: 'fr', href: 'https://subo.gg/fr/polls'},
		]} />
	</head>
	<body>
		<Header translations={translations.header} />
		<main id="main-content">

			<!-- Hero -->
			<section class="poll-hero">
				<div class="container text-center">
					<h1 class="poll-hero__title" set:html={t.hero.title} />
					<p class="poll-hero__subtitle">{t.hero.subtitle}</p>
					<a href="/invite" class="button button--accent-bg">{t.hero.cta}</a>
				</div>
			</section>

			<!-- Section nav pills -->
			<nav class="poll-nav" aria-label="Poll sections">
				<div class="poll-nav__inner">
					{t.nav.map((pill) => (
						<a href={`#${pill.anchor}`} class="poll-nav__pill mono">{pill.label}</a>
					))}
				</div>
			</nav>

			{t.sections.map((section, i) => (
				<section class={`poll-section ${i % 2 === 0 ? 'poll-section--secondary' : 'poll-section--dark'}`} id={section.id}>
					<div class="container">
						<div class="poll-section__header">
							<span class={`poll-label ${i % 2 === 0 ? 'poll-label--accent' : 'poll-label--primary'} mono`}>{section.label}</span>
							<h2 class="poll-section__title">{section.title}</h2>
							<p class="poll-section__sub">{section.sub}</p>
						</div>
						<div class="poll-cards">
							{section.cards.map((card) => (
								<div class="poll-card">
									<span class="poll-card__emoji">{card.emoji}</span>
									<h3 class="poll-card__title">{card.title}</h3>
									<p class="poll-card__desc" set:html={card.desc} />
								</div>
							))}
						</div>
					</div>
				</section>
			))}

			<!-- Picture over time -->
			<section class="poll-section poll-section--secondary">
				<div class="container poll-narrow">
					<h2 class="poll-section__title text-center">{t.outro.title}</h2>
					{t.outro.body.map((para) => (
						<p>{para}</p>
					))}
					<p class="poll-blog-link">
						<a href={t.outro.blogLink.href}>{t.outro.blogLink.text}</a>
					</p>
				</div>
			</section>

			<CTA translations={translations} />
		</main>
		<Footer translations={translations.footer} />
	</body>
</html>

<style>
/* Hero */
.poll-hero {
	padding: 140px 0 80px;
	background: linear-gradient(180deg, var(--dark) 0%, var(--secondary-dark) 100%);
}
.poll-hero__title {
	font-size: clamp(1.8rem, 4.5vw, 3rem);
	font-weight: 800;
	line-height: 1.1;
	margin-bottom: 1.25rem;
}
.poll-hero__subtitle {
	font-size: 1.15rem;
	color: var(--grey-light);
	max-width: 620px;
	margin: 0 auto 2rem;
	line-height: 1.6;
}

/* Section nav */
.poll-nav {
	position: sticky;
	top: 57px;
	z-index: 100;
	background: var(--secondary-dark);
	border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}
.poll-nav__inner {
	display: flex;
	justify-content: center;
	gap: 0.25rem;
	padding: 0.6rem 1rem;
	flex-wrap: wrap;
}
.poll-nav__pill {
	display: inline-block;
	padding: 0.35rem 1rem;
	border-radius: 999px;
	font-size: 0.75rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	color: var(--grey-light);
	text-decoration: none;
	border: 1px solid transparent;
	transition: color 0.15s, border-color 0.15s, background 0.15s;
}
.poll-nav__pill:hover {
	color: var(--accent);
	border-color: var(--accent);
	background: rgba(255, 255, 255, 0.04);
}

/* Sections */
.poll-section {
	padding: 4rem 0;
}
.poll-section--secondary {
	background: var(--secondary-dark);
}
.poll-section--dark {
	background: var(--dark);
}
.poll-section__header {
	text-align: center;
	margin-bottom: 3rem;
}
.poll-section__title {
	font-size: clamp(1.5rem, 3vw, 2.25rem);
	font-weight: 800;
	margin: 0.75rem 0 0.75rem;
	line-height: 1.2;
}
.poll-section__sub {
	color: var(--grey-light);
	font-size: 1.05rem;
	max-width: 580px;
	margin: 0 auto;
	line-height: 1.65;
}

/* Section label pill */
.poll-label {
	display: inline-block;
	font-size: 0.7rem;
	font-weight: 700;
	letter-spacing: 0.12em;
	padding: 0.25rem 0.85rem;
	border-radius: 999px;
}
.poll-label--accent {
	color: var(--accent);
	background: rgba(var(--accent-rgb, 99, 207, 138), 0.12);
	border: 1px solid rgba(var(--accent-rgb, 99, 207, 138), 0.25);
}
.poll-label--primary {
	color: var(--primary);
	background: rgba(88, 101, 242, 0.12);
	border: 1px solid rgba(88, 101, 242, 0.25);
}

/* Cards grid */
.poll-cards {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	gap: 1.25rem;
}
.poll-card {
	background: var(--dark);
	border: 1px solid rgba(255, 255, 255, 0.08);
	border-radius: 12px;
	padding: 1.75rem;
}
.poll-section--dark .poll-card {
	background: var(--secondary-dark);
}
.poll-card__emoji {
	font-size: 1.75rem;
	display: block;
	margin-bottom: 0.75rem;
}
.poll-card__title {
	font-size: 1rem;
	font-weight: 700;
	margin: 0 0 0.5rem;
}
.poll-card__desc {
	font-size: 0.9rem;
	color: var(--grey-light);
	line-height: 1.65;
	margin: 0;
}
.poll-card__desc code {
	font-family: monospace;
	background: rgba(255, 255, 255, 0.08);
	padding: 0.1em 0.35em;
	border-radius: 4px;
	font-size: 0.85em;
}

/* Narrative block */
.poll-narrow {
	max-width: 680px;
}
.poll-narrow p {
	color: var(--grey-light);
	font-size: 1.05rem;
	line-height: 1.7;
	margin: 0 0 1rem;
}
.poll-blog-link {
	text-align: center;
	margin-top: 1.5rem !important;
}
.poll-blog-link a {
	color: var(--accent);
	text-decoration: none;
	font-weight: 600;
}
.poll-blog-link a:hover {
	text-decoration: underline;
}

.text-center {
	text-align: center;
}

/* Responsive */
@media (max-width: 600px) {
	.poll-nav__pill {
		font-size: 0.7rem;
		padding: 0.3rem 0.75rem;
	}
	.poll-cards {
		grid-template-columns: 1fr;
	}
}
</style>
