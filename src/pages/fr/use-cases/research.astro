---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import CTA from '../../../components/CTA.astro';
import Footer from '../../../components/Footer.astro';
import translations from '../../../content/translations/fr.json';

const t = translations.useCasesResearch;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={t.pageTitle} description={t.pageDescription} alternates={[
      {lang: 'x-default', href: 'https://subo.gg/use-cases/research'},
      {lang: 'en', href: 'https://subo.gg/use-cases/research'},
      {lang: 'fr', href: 'https://subo.gg/fr/use-cases/research'},
    ]} />
  </head>
  <body>
    <Header translations={translations.header} />
    <main id="main-content">

      <!-- Hero -->
      <section class="uc-hero">
        <div class="container text-center">
          <span class="uc-eyebrow mono">{t.eyebrow}</span>
          <h1 class="mono">{t.heroTitle}</h1>
          <p class="uc-hero__subtitle">{t.heroSubtitle}</p>
          <a href="/invite" class="button button--accent-bg">{t.heroCta}</a>
        </div>
      </section>

      {t.sections.map((section, i) => (
        <section class={`uc-section ${i % 2 === 0 ? 'uc-section--secondary' : 'uc-section--dark'}`}>
          <div class="container">
            <div class="uc-section__header">
              <span class="uc-label mono">{section.label}</span>
              <h2 class="uc-section__title">{section.title}</h2>
              {section.sub && <p class="uc-section__sub">{section.sub}</p>}
            </div>
            <div class="uc-cards">
              {section.cards.map((card) => (
                <div class="uc-card">
                  <span class="uc-card__emoji">{card.emoji}</span>
                  <h3 class="uc-card__title">{card.title}</h3>
                  <p class="uc-card__desc" set:html={card.desc} />
                </div>
              ))}
            </div>
            {section.screenshot && (
              <figure class="uc-screenshot">
                <img src={section.screenshot.src} alt={section.screenshot.alt} loading="lazy" />
                <figcaption>{section.screenshot.caption}</figcaption>
              </figure>
            )}
            {section.blogLink && (
              <p class="uc-blog-link">
                <a href={section.blogLink.href}>{section.blogLink.text}</a>
              </p>
            )}
          </div>
        </section>
      ))}

      <!-- Examples -->
      <section class="uc-section uc-section--secondary">
        <div class="container">
          <div class="uc-section__header">
            <span class="uc-label mono">{t.examplesLabel}</span>
            <h2 class="uc-section__title">{t.examplesTitle}</h2>
          </div>
          <div class="uc-examples">
            {t.examples.map((ex) => <span class="uc-example">{ex}</span>)}
          </div>
        </div>
      </section>

      <CTA translations={translations} />
    </main>
    <Footer translations={translations.footer} />
  </body>
</html>

<style>
.uc-hero {
  padding: 140px 0 80px;
  background:
    radial-gradient(70% 55% at 50% 0%, var(--bg-glow-pink), transparent 70%),
    var(--bg-base);
}
.uc-eyebrow {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--accent);
  margin-bottom: 0.75rem;
}
.uc-hero h1 {
  font-family: "IBM Plex Mono", "Source Code Pro", monospace;
  letter-spacing: -0.02em;
  font-size: clamp(1.8rem, 4.5vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1.25rem;
}
.uc-hero__subtitle {
  font-size: 1.15rem;
  color: var(--grey-light);
  max-width: 620px;
  margin: 0 auto 2rem;
}
.uc-section { padding: 4rem 0; }
.uc-section--secondary { background: transparent; }
.uc-section--dark { background: transparent; }
.uc-section__header { text-align: center; margin-bottom: 3rem; }
.uc-section__title {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 800;
  margin: 0.75rem 0;
  line-height: 1.2;
}
.uc-section__sub {
  color: var(--grey-light);
  font-size: 1.05rem;
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.65;
}
.uc-label {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
  color: var(--accent);
  background: rgba(var(--accent-rgb, 99, 207, 138), 0.12);
  border: 1px solid rgba(var(--accent-rgb, 99, 207, 138), 0.25);
}
.uc-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}
.uc-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 1.75rem;
}
.uc-card__emoji { font-size: 1.75rem; display: block; margin-bottom: 0.75rem; }
.uc-card__title { font-size: 1rem; font-weight: 700; margin: 0 0 0.5rem; }
.uc-card__desc { font-size: 0.9rem; color: var(--grey-light); line-height: 1.65; margin: 0; }
.uc-card__desc a { color: var(--accent); text-decoration: none; }
.uc-card__desc a:hover { text-decoration: underline; }
.uc-examples {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  justify-content: center;
  max-width: 820px;
  margin: 0 auto;
}
.uc-example {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 999px;
  padding: 0.5rem 1rem;
  font-size: 0.92rem;
}
.uc-screenshot { margin: 0 0 1.5rem; }
.uc-screenshot img {
  display: block;
  width: 100%;
  border-radius: 12px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  margin-bottom: 0.75rem;
}
.uc-screenshot figcaption {
  font-size: 0.82rem;
  color: var(--grey-light);
  text-align: center;
  opacity: 0.7;
}
.uc-blog-link { text-align: center; margin: 0; }
.uc-blog-link a { font-size: 0.9rem; color: var(--accent); text-decoration: none; }
.uc-blog-link a:hover { text-decoration: underline; }
@media (max-width: 600px) {
  .uc-cards { grid-template-columns: 1fr; }
}
</style>
